
alias mv='mv -i'                   # Ask for confirmation
alias cp='cp -i'                   # Ask for confirmation
alias ln='ln -i'                   # Ask for confirmation
alias ll='ls -lah'                 # Use a long listing format
alias la='ls -A'                   # List all except . and ..
alias l='ls -CF'                   # Compact listing
alias du='du -h'                   # Human-readable disk usage
alias df='df -h'                   # Human-readable filesystem usage
alias mtr='mtr -z --displaymode=1' # Display stripchart and AS numbers

alias ls='ls --color=auto'         # Colorize the ls output
alias diff='diff --color=auto'     # Colorize the diff output
alias egrep='egrep --color=auto'   # Colorize the grep output
alias fgrep='fgrep --color=auto'   # Colorize the grep output
alias grep='grep --color=auto'     # Colorize the grep output
alias ip='ip --color=auto'         # Colorize the ip output
alias less='less -R'               # Preserve colored output
